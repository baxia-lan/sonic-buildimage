{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*secret*)",
      "Read(./**/*token*)",
      "Bash(git remote add*)",
      "Bash(git remote remove*)",
      "Bash(git remote set-url*)",
      "Bash(gh pr create*)",
      "Bash(gh repo create*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(git rebase*)",
      "Bash(git commit --amend*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-dangerous-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-bazel-edit.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/policy-scan-edits.sh"
          }
        ]
      }
    ]
  }
}
