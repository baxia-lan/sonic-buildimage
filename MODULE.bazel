"""SONiC Buildimage — Bazel bzlmod root module.

Hermetic build system using:
  - Pre-built GCC 12.5.0 toolchain (no host compiler dependency)
  - rules_distroless for Debian package resolution at fetch time
  - rules_oci for container image assembly
  - Pinned snapshot.debian.org mirrors for reproducibility
"""

module(
    name = "sonic_buildimage",
    version = "0.0.0",
    bazel_compatibility = [">=8.0.0"],
    compatibility_level = 1,
)

# ── Core ──────────────────────────────────────────────────────────────────────
bazel_dep(name = "bazel_skylib", version = "1.8.2")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "rules_pkg", version = "1.0.1")

# ── Language rules ────────────────────────────────────────────────────────────
bazel_dep(name = "rules_cc", version = "0.2.17")
bazel_dep(name = "googletest", version = "1.15.2")
bazel_dep(name = "glog", version = "0.7.1")
bazel_dep(name = "rules_python", version = "1.7.0")
bazel_dep(name = "rules_go", version = "0.50.1")
bazel_dep(name = "gazelle", version = "0.40.0")

# ── C/C++ foreign build systems (autotools, cmake) ───────────────────────────
bazel_dep(name = "rules_foreign_cc", version = "0.13.0")

# ── SONiC submodules (resolved via local registry) ───────────────────────────
bazel_dep(name = "sonic_swss_common", version = "0.0.0")

# ── OCI / container images ────────────────────────────────────────────────────
bazel_dep(name = "rules_oci", version = "2.0.0")

# ── Build utilities ───────────────────────────────────────────────────────────
bazel_dep(name = "bazel_lib", version = "3.1.1")
bazel_dep(name = "buildifier_prebuilt", version = "7.3.1")

# ── Distroless (Debian package resolution at fetch time) ─────────────────────
bazel_dep(name = "rules_distroless", version = "0.3.8")

# ── Hermetic LLVM/Clang 18 Toolchain (sonic-bazel pattern) ───────────────────
# Downloads hermetic Clang/LLVM, links against a Bookworm sysroot assembled
# from .deb packages extracted during bazel fetch. No host compiler needed.
bazel_dep(name = "toolchains_llvm", version = "1.7.0")

llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm")

llvm.toolchain(
    name = "llvm_toolchain",
    llvm_versions = {
        "": "18.1.8",
        "darwin-x86_64": "15.0.7",
    },
    link_flags = {
        "": ["-Wl,-rpath,$ORIGIN/../lib", "-Wl,-rpath,$ORIGIN/../lib/x86_64-linux-gnu", "-lm"],
    },
    cxx_flags = {"": ["-std=c++17"]},
)

# Hermetic sysroot: .deb packages extracted during bazel fetch
llvm.sysroot(
    name = "llvm_toolchain",
    label = "@bookworm_sysroot//:sysroot",
    targets = ["linux-x86_64"],
)

use_repo(llvm, "llvm_toolchain", "llvm_toolchain_llvm")

register_toolchains("@llvm_toolchain//:all")

