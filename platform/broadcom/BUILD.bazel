"""Broadcom platform — sonic-broadcom.bin ONIE installer image.

Size budget: sonic-broadcom.bin ≤ 400 MB (CLAUDE.md hard limit).

Phase 3 optimizations applied:
  - Kernel module filtering via modules.allowlist (~20-40 MB savings)
  - Debug symbol stripping on all layers
  - dpkg path-exclude for docs/man/locale
  - APT recommends/suggests disabled
  - frr built with --disable-doc --disable-grpc

Outputs:
  - :broadcom_modules      — filtered kernel modules
  - :sonic_broadcom_rootfs  — rootfs squashfs for ONIE installer
  - :sonic_broadcom_bin     — sonic-broadcom.bin ONIE installer (must be ≤ 400 MB)
"""

load("@rules_pkg//pkg:tar.bzl", "pkg_tar")
load("//rules/bazel/onie:onie.bzl", "onie_image", "sonic_rootfs")
load("//rules/bazel/onie:module_filter.bzl", "filtered_modules")

package(default_visibility = ["//visibility:public"])

# ── Phase 3: Kernel module filtering ─────────────────────────────────────────
# Only ~65 modules from the allowlist are kept. All others are stripped.
filtered_modules(
    name = "broadcom_modules",
    modules_tar = "//src/sonic-linux-kernel:kernel_modules_tar",
    allowlist = ":modules.allowlist",
    size_budget_mb = 60,
)

# ── Broadcom SAI + platform drivers layer ────────────────────────────────────
# Platform-specific .deb packages for Broadcom ASICs.
# TODO(migration): These debs come from the Broadcom SDK which is distributed
# as a binary blob. They are currently fetched by platform/broadcom/one-image.mk.
# In Bazel, they will be fetched via a repository_rule in MODULE.bazel.
filegroup(
    name = "broadcom_platform_debs",
    srcs = glob(["*.deb"]),
)

# ── All service images for Broadcom platform ────────────────────────────────
BROADCOM_SERVICE_IMAGES = [
    "//dockers/docker-database:docker_database_tarball",
    "//dockers/docker-fpm-frr:docker_fpm_frr_tarball",
    "//dockers/docker-orchagent:docker_orchagent_tarball",
    "//dockers/docker-teamd:docker_teamd_tarball",
    "//dockers/docker-snmp:docker_snmp_tarball",
    "//dockers/docker-lldp:docker_lldp_tarball",
    "//dockers/docker-dhcp-relay:docker_dhcp_relay_tarball",
    "//dockers/docker-router-advertiser:docker_router_advertiser_tarball",
    "//dockers/docker-nat:docker_nat_tarball",
    "//dockers/docker-sflow:docker_sflow_tarball",
    "//dockers/docker-sonic-gnmi:docker_sonic_gnmi_tarball",
    "//dockers/docker-sonic-telemetry:docker_sonic_telemetry_tarball",
    "//dockers/docker-eventd:docker_eventd_tarball",
    "//dockers/docker-sonic-mgmt-framework:docker_sonic_mgmt_framework_tarball",
    "//dockers/docker-platform-monitor:docker_platform_monitor_tarball",
    "//dockers/docker-macsec:docker_macsec_tarball",
    "//dockers/docker-mux:docker_mux_tarball",
    "//dockers/docker-stp:docker_stp_tarball",
    "//dockers/docker-iccpd:docker_iccpd_tarball",
]

# ── Broadcom rootfs ──────────────────────────────────────────────────────────
sonic_rootfs(
    name = "sonic_broadcom_rootfs",
    platform = "broadcom",
    service_images = BROADCOM_SERVICE_IMAGES,
    platform_packages = [":broadcom_platform_debs"],
)

# ── sonic-broadcom.bin ONIE installer ────────────────────────────────────────
# Size budget: ≤ 400 MB (enforced in cloudbuild-nightly.yaml).
onie_image(
    name = "sonic_broadcom_bin",
    rootfs = ":sonic_broadcom_rootfs",
    kernel = "//src/sonic-linux-kernel:vmlinuz",
    platform_modules = [":broadcom_modules"],
    platform = "broadcom",
    machine = "x86_64-broadcom_common",
    version = "0.0.0-bazel",
)
