load("//rules/bazel/deb:deb.bzl", "deb_package_set")

package(default_visibility = ["//visibility:public"])

deb_package_set(
    name = "rdb_cli_debs",
    srcs = glob(
        ["**/*"],
        exclude = [
            ".git/**",
            "BUILD.bazel",
        ],
    ),
    debian_dir = "debian",
    version = "0.1",
    declared_outputs = ["rdb-cli_0.1_$(ARCH).deb"],
    visibility = ["//visibility:public"],
)
