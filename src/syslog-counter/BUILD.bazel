"""syslog-counter -- migrated from rules/syslog-counter.mk."""

load("//rules/bazel/deb:deb.bzl", "deb_package_set")

package(default_visibility = ["//visibility:public"])

deb_package_set(
    name = "syslog_counter_debs",
    srcs = glob(
        ["**/*"],
        exclude = [
            ".git/**",
            "BUILD.bazel",
        ],
    ),
    build_deps = [],
    debian_dir = "debian",
    declared_outputs = [
        "syslog-counter_1.0.0_$(ARCH).deb",
    ],
    version = "1.0.0",
    visibility = ["//visibility:public"],
)

alias(
    name = "syslog_counter",
    actual = ":syslog_counter_debs",
    visibility = ["//visibility:public"],
)
