# SONiC Buildimage — Bazel 8 flags
# Hermetic build: no host tools, no network in build actions.

# ── JVM heap note (per-step, not global) ─────────────────────────────────────
# Do NOT set `startup --host_jvm_args=-Xmx16g` here. It applies to every step
# and combines with --local_ram_resources=20000 to exceed the 28.8GB
# N1_HIGHCPU_32 capacity, causing kernel OOM / INTERNAL_ERROR (build
# 9d10cdf4 on SHA 5c55bf13b at ~57m in build-orchagent).
# The heap bump is only needed for //platform/vs:docker_sonic_vs_tarball's
# analysis phase (~27k targets + ~200 bookworm_* apt repos). Apply it on the
# command line in that step only (cloudbuild.yaml build-docker-sonic-vs),
# and lower --local_ram_resources correspondingly so JVM + action RAM +
# docker/system ≤ machine RAM.

# ── Local registry (submodule workspace boundary fix) ────────────────────────
# Local registry must come first so submodule modules resolve locally.
# BCR must be listed explicitly because --registry overrides the default.
common --registry=file://%workspace%/tools/bazel/registry
common --registry=https://bcr.bazel.build

# ── Repository-rule HTTP resilience ──────────────────────────────────────────
# BCR → github.com archive fetches intermittently return 504 Gateway Timeout
# at load phase (evidence: build 30396945 on 246ddc314 — rules_oci-v2.0.0
# fetch from github.com/bazel-contrib/rules_oci/releases returned 504,
# failing build-orchagent before any build action ran).
# Retry transient HTTP errors on repository-rule downloads (BCR metadata,
# http_archive, etc.) up to 6 times. Applies at Bazel-server level so every
# command picks it up; no effect on in-sandbox network (still blocked).
common --experimental_repository_downloader_retries=6
common --http_timeout_scaling=2.0

# Each Cloud Build step uses a separate --output_user_root
# (/workspace/.cache/bazel-orch, bazel-kernel, bazel-vs, etc.) to avoid
# cross-step lock contention on the output-base, but that also means
# every step independently refetches every external archive — so any
# github.com 504 in any step fails the whole build (evidence: build
# 6cd2aafb on c6a6b1ff7 — build-orchagent succeeded fetching rules_oci,
# then build-docker-sonic-vs 30min later tried to fetch rules_shell from
# github releases and hit 504).
# --repository_cache lives outside output_user_root and is documented
# as safe for concurrent readers/writers, so pointing every Bazel step
# at /workspace/.cache/bazel-repo means the first successful fetch of
# any http_archive is shared across all downstream steps. Halves the
# total number of github.com requests needed per build.
common --repository_cache=/workspace/.cache/bazel-repo

# ── Hermeticity ──────────────────────────────────────────────────────────────
build --incompatible_strict_action_env=true
build --sandbox_default_allow_network=false
build --action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build --action_env=SOURCE_DATE_EPOCH=0
build --action_env=USER=bazel
build --action_env=HOME
build --action_env=DOCKER_HOST

# ── Sandbox ──────────────────────────────────────────────────────────────────
build --spawn_strategy=sandboxed
build --verbose_failures

# ── C++ toolchain ─────────────────────────────────────────────────────────────
build --incompatible_enable_cc_toolchain_resolution

# ── Platform ─────────────────────────────────────────────────────────────────
build --enable_platform_specific_config
build --platforms=//platforms:linux_amd64

# ── Output ────────────────────────────────────────────────────────────────────
build --show_progress_rate_limit=5
build --show_timestamps

# ── Test ──────────────────────────────────────────────────────────────────────
test --test_output=errors
test --test_timeout=300

# ── CI (--config=ci) ─────────────────────────────────────────────────────────
build:ci --remote_cache=https://storage.googleapis.com/sonic-bazel-cache
build:ci --google_default_credentials
build:ci --remote_upload_local_results=true
build:ci --remote_download_toplevel
build:ci --jobs=HOST_CPUS
build:ci --noshow_progress
build:ci --spawn_strategy=local
build:ci --strategy=CopyToDirectory=local
build:ci --verbose_failures

# ── GitHub Actions CI (--config=github) ──────────────────────────────────────
# Uses same GCS remote cache as Cloud Build. Requires GOOGLE_APPLICATION_CREDENTIALS
# secret set in GitHub Actions (base64-encoded service account JSON key).
build:github --remote_cache=https://storage.googleapis.com/sonic-bazel-cache
build:github --google_default_credentials
build:github --remote_upload_local_results=true
build:github --remote_download_toplevel
build:github --jobs=HOST_CPUS
build:github --spawn_strategy=local
build:github --strategy=CopyToDirectory=local
build:github --verbose_failures

# ── Remote Build Execution (--config=rbe) ─────────────────────────────────────
build:rbe --config=ci
build:rbe --remote_executor=grpcs://remotebuildexecution.googleapis.com
build:rbe --jobs=200

# ── Local dev on macOS (genrules need Docker for Linux tools) ─────────────────
build:local --spawn_strategy=local
build:local --jobs=2

# ── Cross-compilation ────────────────────────────────────────────────────────
build:arm64 --platforms=//platforms:linux_arm64
build:armhf --platforms=//platforms:linux_armhf

# ── Debug ─────────────────────────────────────────────────────────────────────
build:debug --compilation_mode=dbg
build:debug --strip=never
build:debug --sandbox_debug

# Bazel 8 compat: allow empty globs (Bazel 7 default)
common --noincompatible_disallow_empty_glob

