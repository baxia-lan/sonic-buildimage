# SONiC Buildimage — Bazel flags
# Applies to all `bazel build`, `bazel test`, `bazel run` invocations.

# ── Hermeticity (non-negotiable) ─────────────────────────────────────────────
build --incompatible_strict_action_env=true
build --sandbox_default_allow_network=false
# Explicit PATH so strict_action_env doesn't break shell tools in genrules.
build --action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# Reproducible packaging timestamps.
build --action_env=SOURCE_DATE_EPOCH=0
# No accidental host env leaking into builds.
build --action_env=USER=bazel
# Allow Docker CLI to find its socket in genrules.
# HOME is needed for Docker config; DOCKER_HOST for the socket.
build --action_env=HOME
build --action_env=DOCKER_HOST

# ── Sandbox ──────────────────────────────────────────────────────────────────
build --spawn_strategy=sandboxed
# Show full command lines for failed actions.
build --verbose_failures

# ── Platform defaults ─────────────────────────────────────────────────────────
build --enable_platform_specific_config
# Default build platform: amd64. Override with --platforms=//platforms:arm64, etc.
build --platforms=//platforms:linux_amd64

# ── C++ toolchain ─────────────────────────────────────────────────────────────
build --incompatible_enable_cc_toolchain_resolution

# ── Output ────────────────────────────────────────────────────────────────────
# Show build progress.
build --show_progress_rate_limit=5
# Timestamp each action log line.
build --show_timestamps

# ── Test ─────────────────────────────────────────────────────────────────────
test --test_output=errors
test --test_timeout=300

# ── CI config (activate with --config=ci) ────────────────────────────────────
build:ci --remote_cache=grpcs://remotebuildexecution.googleapis.com
build:ci --google_default_credentials
build:ci --remote_upload_local_results=true
build:ci --remote_download_toplevel
build:ci --jobs=64
# Set PROJECT_ID before using CI config:
#   bazel build --config=ci \
#     --remote_instance_name=projects/$PROJECT_ID/instances/sonic-cache ...
build:ci --noshow_progress
build:ci --show_result=0

# ── Remote Build Execution (activate with --config=rbe) ──────────────────────
build:rbe --config=ci
build:rbe --remote_executor=grpcs://remotebuildexecution.googleapis.com
build:rbe --jobs=200
build:rbe --strategy=remote
# Debian package builds run inside the sonic-slave container on RBE workers.
build:rbe --experimental_docker_use_customized_images
build:rbe --experimental_docker_network=off

# ── Debug config (--config=debug) ─────────────────────────────────────────────
build:debug --compilation_mode=dbg
build:debug --strip=never
build:debug --sandbox_debug

# ── Cross-compilation configs ─────────────────────────────────────────────────
build:arm64 --platforms=//platforms:linux_arm64
build:armhf --platforms=//platforms:linux_armhf
