P4LANG_COMMON_DEP_FILES := $(SONIC_COMMON_FILES_LIST) rules/p4lang.mk rules/p4lang.dep
P4LANG_COMMON_DEP_FILES += $(SONIC_COMMON_BASE_FILES_LIST)

SPATH       := $($(P4LANG_PI)_SRC_PATH)
DEP_FILES   := $(P4LANG_COMMON_DEP_FILES)
DEP_FILES   += $(wildcard \
	$(SPATH)/Makefile \
	$(SPATH)/p4lang-pi_* \
	$(SPATH)/p4lang-pi.patch/*)

$(P4LANG_PI)_CACHE_MODE  := GIT_CONTENT_SHA
$(P4LANG_PI)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(P4LANG_PI)_DEP_FILES   := $(DEP_FILES)
$(P4LANG_PI)_CACHE_OVERRIDE := $(SONIC_DPKG_CACHE_METHOD_OVERRIDE)

SPATH       := $($(P4LANG_BMV2)_SRC_PATH)
DEP_FILES   := $(P4LANG_COMMON_DEP_FILES)
DEP_FILES   += $(wildcard \
	$(SPATH)/Makefile \
	$(SPATH)/p4lang-bmv2_* \
	$(SPATH)/p4lang-bmv2.patch/*)

$(P4LANG_BMV2)_CACHE_MODE  := GIT_CONTENT_SHA
$(P4LANG_BMV2)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(P4LANG_BMV2)_DEP_FILES   := $(DEP_FILES)
$(P4LANG_BMV2)_CACHE_OVERRIDE := $(SONIC_DPKG_CACHE_METHOD_OVERRIDE)

SPATH       := $($(P4LANG_P4C)_SRC_PATH)
DEP_FILES   := $(P4LANG_COMMON_DEP_FILES)
DEP_FILES   += $(wildcard \
	$(SPATH)/Makefile \
	$(SPATH)/p4lang-p4c_* \
	$(SPATH)/p4lang-p4c.patch/*)

$(P4LANG_P4C)_CACHE_MODE  := GIT_CONTENT_SHA
$(P4LANG_P4C)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(P4LANG_P4C)_DEP_FILES   := $(DEP_FILES)
$(P4LANG_P4C)_CACHE_OVERRIDE := $(SONIC_DPKG_CACHE_METHOD_OVERRIDE)
