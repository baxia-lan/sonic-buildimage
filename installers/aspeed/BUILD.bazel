load("//bazel/sonic:defs.bzl", "sonic_export_to_target_tree")
load("//installers:data.bzl", "ASPEED_ONIE")
load("//installers:defs.bzl", "sonic_installer_variant")

package(default_visibility = ["//visibility:public"])

sonic_installer_variant(
    name = "onie",
    platform = "//platforms/aspeed:platform",
    data = ASPEED_ONIE,
)

sonic_export_to_target_tree(
    name = "target_tree",
    exports = {
        ":onie_lock": "target/installers/sonic-aspeed-arm64.bin.lock.json",
    },
)
