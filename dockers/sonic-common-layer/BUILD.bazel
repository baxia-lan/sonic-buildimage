"""sonic-common-layer — shared base for all SONiC service containers.

Phase 2: replaces the docker-base + docker-config-engine layer pair.

Before (5-layer chain):
  debian:bullseye
    └── docker-base-bullseye         (~200 MB)
        └── docker-config-engine-bullseye  (+~80 MB supervisord, j2, py pkgs)
            └── docker-swss-layer-bullseye  (+~300 MB libswsscommon)
                └── <service>               (+binary)

After (3-layer target):
  gcr.io/distroless/base-debian12    (~20 MB, no shell)
    └── sonic-common-layer           (supervisord, libssl, redis-tools, ~130 MB)
        └── <service>                (libswsscommon + binary, ~100 MB)

Size budget: sonic-common-layer must be ≤ 150 MB (see CLAUDE.md).

What's in this layer vs the old docker-base + docker-config-engine:
  KEPT:   supervisord, redis-tools, libdbus, libjansson, libzmq, iproute2, rsyslog
  KEPT:   /var/log/supervisor, /etc/supervisor/conf.d skeleton
  REMOVED: apt, pip, python3-pip, build-essential (not needed at runtime)
  REMOVED: perl, exim4, vim-tiny (not needed at runtime)
  REMOVED: docker-config-engine j2 rendering (moved to build time via //rules/bazel/j2)
  REMOVED: python-is-python3 (services that need Python declare it explicitly)

The config-engine j2 rendering that was done at container start is now:
  - Static templates → rendered at Bazel build time via //rules/bazel/j2:j2.bzl
  - Dynamic templates (interface IPs, etc.) → rendered at runtime by a minimal
    Python script (//files/config-engine:render_dynamic.py), not a full image layer.
"""

load("@rules_oci//oci:defs.bzl", "oci_image")
load("@rules_pkg//pkg:tar.bzl", "pkg_tar")
load("//rules/bazel/oci:oci.bzl", "sonic_oci_image", "sonic_oci_layer")
load("//rules/bazel/oci:strip_layer.bzl", "stripped_layer")

package(default_visibility = ["//visibility:public"])

# ── supervisord configuration skeleton ────────────────────────────────────────
pkg_tar(
    name = "supervisord_skel_layer",
    srcs = [
        "//files/supervisord:base.conf",
        "//files/supervisord:supervisord_env.conf",
    ],
    remap_paths = {
        "files/supervisord/base.conf": "/etc/supervisor/supervisord.conf",
        "files/supervisord/supervisord_env.conf": "/etc/supervisor/conf.d/supervisord_env.conf",
    },
    mode = "0644",
)

# ── rsyslog configuration ────────────────────────────────────────────────────
pkg_tar(
    name = "rsyslog_layer",
    srcs = [
        "//files/rsyslog:rsyslog.conf",
    ],
    remap_paths = {
        "files/rsyslog/rsyslog.conf": "/etc/rsyslog.conf",
    },
    mode = "0644",
)

# ── dpkg exclude configuration (no docs, no man pages) ───────────────────────
# This replaces the dpkg_01_drop file from docker-base.
# It tells dpkg not to install man pages, docs, or locale data.
pkg_tar(
    name = "dpkg_excludes_layer",
    srcs = ["//files/dpkg:01_sonic_excludes"],
    remap_paths = {
        "files/dpkg/01_sonic_excludes": "/etc/dpkg/dpkg.cfg.d/01_sonic_excludes",
    },
    mode = "0644",
)

# ── apt package layer ─────────────────────────────────────────────────────────
# These packages are pre-installed from the Debian repository.
# Only packages actually needed at runtime are listed here.
# All development packages (headers, -dev) are absent from this layer.
#
# To add a package: verify with ldd that the binary needs it, document in
# docs/removed_deps.md if removing.
#
# This layer is built by a genrule that runs apt-get inside the
# distroless-compatible bootstrap container. The resulting tar is
# deterministic (SOURCE_DATE_EPOCH=0, sorted file list).
genrule(
    name = "common_apt_layer",
    srcs = [
        "//files/dpkg:01_sonic_excludes",
        "//files/dpkg:02_sonic_no_recommends",
    ],
    outs = ["common_apt_layer.tar"],
    cmd = """
set -euo pipefail
# This genrule runs on RBE inside a Debian bookworm environment.
# It installs the listed packages into a temporary rootfs and
# produces a tar layer suitable for oci_image.
ROOTFS=$$(mktemp -d)
trap 'rm -rf "$$ROOTFS"' EXIT

# Install dpkg path exclusions BEFORE installing any packages.
# This prevents man pages, docs, locales from being written at all.
mkdir -p $$ROOTFS/etc/dpkg/dpkg.cfg.d $$ROOTFS/etc/apt/apt.conf.d
cp $(location //files/dpkg:01_sonic_excludes) $$ROOTFS/etc/dpkg/dpkg.cfg.d/01_sonic_excludes
cp $(location //files/dpkg:02_sonic_no_recommends) $$ROOTFS/etc/apt/apt.conf.d/02_no_recommends

apt-get -y -o Dir::Cache=$$ROOTFS/var/cache/apt \\
           -o Dir::State=$$ROOTFS/var/lib/apt \\
           -o APT::Get::AllowUnauthenticated=true \\
           -o DPkg::options::=--root=$$ROOTFS \\
  install --no-install-recommends \\
    iproute2 \\
    net-tools \\
    redis-tools \\
    libdaemon0 \\
    libdbus-1-3 \\
    libjansson4 \\
    libzmq5 \\
    libwrap0 \\
    libssl3 \\
    rsyslog \\
    procps \\
    jq \\
    -o Dir::Cache::archives=$$ROOTFS/debs

# NOT installed (Phase 3 removals):
#   perl          — only needed by dpkg postinst; no dpkg at runtime
#   vim-tiny      — debug tool, not needed in production
#   python3-pip   — packages installed at build time, not runtime
#   exim4         — was pulled in as rsyslog Recommends; blocked by no-recommends
#   curl/wget     — not needed at runtime; health checks use Python

# Install supervisord from pip into the rootfs.
pip3 install --no-cache-dir --target $$ROOTFS/usr/local/lib/python3/dist-packages \\
    supervisor==4.2.1 \\
    supervisord-dependent-startup==1.4.0

# Create supervisord state dirs.
mkdir -p $$ROOTFS/var/log/supervisor $$ROOTFS/etc/supervisor/conf.d

# Phase 3: strip debug symbols from all shared libraries
find "$$ROOTFS" -name '*.so*' -type f -exec strip --strip-debug {} \\; 2>/dev/null || true

# Phase 3: clean up documentation that dpkg excludes may have missed
rm -rf $$ROOTFS/usr/share/man $$ROOTFS/usr/share/doc $$ROOTFS/usr/share/info \\
       $$ROOTFS/usr/share/locale $$ROOTFS/usr/share/i18n \\
       $$ROOTFS/usr/share/groff $$ROOTFS/usr/share/lintian \\
       $$ROOTFS/usr/share/bash-completion \\
       $$ROOTFS/var/cache/man 2>/dev/null || true

# Phase 3: remove Python bytecode caches
find "$$ROOTFS" -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true

# Create deterministic tar (SOURCE_DATE_EPOCH=0, sorted).
SOURCE_DATE_EPOCH=0 tar \\
  --sort=name \\
  --mtime=@0 \\
  --owner=0 --group=0 \\
  -C $$ROOTFS \\
  -cf $(OUTS) \\
  --exclude=./var/cache \\
  --exclude=./var/lib/apt \\
  --exclude=./debs \\
  .
""",
    tags = [
        "requires-network",
        "no-cache",
    ],
)

# ── Phase 3: Size budget enforcement ──────────────────────────────────────────
# sonic-common-layer must be ≤ 150 MB (see CLAUDE.md).
stripped_layer(
    name = "common_apt_layer_stripped",
    src = ":common_apt_layer",
    size_budget_mb = 150,
)

# ── sonic-common-layer OCI image ──────────────────────────────────────────────
sonic_oci_image(
    name = "sonic_common_layer",
    base = "@distroless_base_debian12",
    tars = [
        ":common_apt_layer_stripped",
        ":supervisord_skel_layer",
        ":rsyslog_layer",
        ":dpkg_excludes_layer",
    ],
    env = {
        "DEBIAN_FRONTEND": "noninteractive",
        "LANG": "C.UTF-8",
        "LC_ALL": "C.UTF-8",
    },
    labels = {
        "org.opencontainers.image.title": "sonic-common-layer",
        "org.opencontainers.image.description": "Shared SONiC service base layer",
    },
)
