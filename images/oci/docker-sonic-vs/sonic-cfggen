def _render_swss_vars(ctx: Dict[str, Any]) -> str:
    localhost = ctx["DEVICE_METADATA"]["localhost"]
    swss_vars = {
        "asic_type": ctx.get("asic_type", os.environ.get("ASIC_TYPE", DEFAULT_ASIC_TYPE)),
        "asic_id": localhost.get("asic_id", "0"),
        "mac": localhost.get("mac", _mac_from_eth0()),
        "resource_type": localhost.get("resource_type", ""),
        "synchronous_mode": "disable" if localhost.get("synchronous_mode") == "disable" else "enable",
        "dual_tor": "enable" if localhost.get("type") == "ToRRouter" and localhost.get("subtype") == "DualToR" else "disable",
        "dscp_remapping": "enable" if ctx.get("SYSTEM_DEFAULTS", {}).get("tunnel_qos_remap", {}).get("status") == "enabled" else "disable",
        "switch_type": localhost.get("switch_type", DEFAULT_SWITCH_TYPE),
    }
    if "asic_subtype" in ctx and ctx["asic_subtype"]:
        swss_vars["asic_subtype"] = ctx["asic_subtype"]
    if localhost.get("supporting_bulk_counter_groups"):
        swss_vars["supporting_bulk_counter_groups"] = ",".join(localhost["supporting_bulk_counter_groups"])
    return json.dumps(swss_vars, indent=4) + "\n"


