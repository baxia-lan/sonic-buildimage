#!/usr/bin/env python3
"""Minimal SONiC cfggen for docker-sonic-vs runtime readiness.

This implementation intentionally covers only the runtime paths exercised by
the VS docker bootstrap and the swss DVS fixture:

- render supervisord.conf.j2 for docker-init.sh
- render init_cfg.json.j2
- render swss_vars.j2
- render copp_cfg.j2
- render hostname.j2
- render arp_update_vars.j2
- merge JSON/YAML fragments and write CONFIG_DB
- evaluate simple -v lookups used by start.sh and related scripts

It avoids the full legacy config-engine wheel stack so the image can stay
Bazel-owned and hermetic for the VS runtime path.
"""

from __future__ import annotations

