        return f"{chassis_db} redis_chassis.server\n"
    return "\n"


def _render_arp_update_vars(ctx: Dict[str, Any]) -> str:
    def _join_names(table_name: str) -> str:
        table = ctx.get(table_name) or {}
        names: List[str] = []
        for key, value in table.items():
            if isinstance(value, dict) and value:
                # Best-effort: use entries with an IPv6-like prefix if provided.
                prefix = next((v for v in value.values() if isinstance(v, str) and ":" in v), None)
                if prefix:
                    names.append(str(key).split("|", 1)[0])
            else:
                names.append(str(key).split("|", 1)[0])
        return " ".join(dict.fromkeys(names))

    localhost = ctx.get("DEVICE_METADATA", {}).get("localhost", {})
    output = {
        "switch_type": localhost.get("switch_type", ""),
        "type": localhost.get("type", ""),
        "interface": _join_names("INTERFACE"),
        "pc_interface": _join_names("PORTCHANNEL_INTERFACE"),
        "vlan_sub_interface": _join_names("VLAN_SUB_INTERFACE"),
        "vlan": " ".join((ctx.get("VLAN") or {}).keys()),
        "static_route_nexthops": " ".join(
            str(attrs.get("nexthop", "")).replace(",", " ").lower()
            for _, attrs in (ctx.get("STATIC_ROUTE") or {}).items()
            if isinstance(attrs, dict) and attrs.get("nexthop")
        ),
        "static_route_ifnames": " ".join(
            str(attrs.get("ifname", "")).replace(",", " ")
            for _, attrs in (ctx.get("STATIC_ROUTE") or {}).items()
            if isinstance(attrs, dict) and attrs.get("ifname")
        ),
    }
    return json.dumps(output, indent=4) + "\n"


def _render_template(template: str, ctx: Dict[str, Any], enable_asan: str) -> str:
    base = os.path.basename(template)
    if base == "supervisord.conf.j2":
        return _render_supervisord(enable_asan)
    if base == "init_cfg.json.j2":
        return _render_init_cfg(ctx)
    if base == "swss_vars.j2":
        return _render_swss_vars(ctx)
    if base == "copp_cfg.j2":
        return _render_copp_cfg(ctx)
    if base == "hostname.j2":
        return _render_hostname(ctx)
    if base == "arp_update_vars.j2":
        return _render_arp_update_vars(ctx)

    raise SystemExit(f"Unsupported template for minimal sonic-cfggen: {template}")


def _write_config_db(data: Dict[str, Any]) -> None:
    for table_name, table_data in data.items():
        if table_name == "DEVICE_RUNTIME_METADATA":
            continue
        if not isinstance(table_data, dict):
            continue
        for key, value in table_data.items():
            if isinstance(value, dict):
                items = []
                for field, field_value in value.items():
                    if isinstance(field_value, (dict, list)):
                        field_value = json.dumps(field_value, sort_keys=True)
                    else:
                        field_value = str(field_value)
                    items.extend([field, field_value])
            else:
                items = ["value", str(value)]

            cmd = ["sonic-db-cli", "CONFIG_DB", "HSET", f"{table_name}|{key}"] + items
            subprocess.run(cmd, check=True)


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-a", dest="a")
    parser.add_argument("-d", dest="d", action="store_true")
    parser.add_argument("-H", dest="host", action="store_true")
    parser.add_argument("-j", dest="j", action="append")
    parser.add_argument("-m", dest="minigraph")
    parser.add_argument("-M", dest="device_desc")
    parser.add_argument("-n", dest="namespace")
    parser.add_argument("-p", dest="platform_json")
    parser.add_argument("-t", dest="template")
    parser.add_argument("-v", dest="var")
    parser.add_argument("-y", dest="y", action="append")
    parser.add_argument("-k", dest="hwsku")
    parser.add_argument("--print-data", dest="print_data", action="store_true")
    parser.add_argument("--write-to-db", dest="write_to_db", action="store_true")
    parser.add_argument("--help", action="help")

    args, _unknown = parser.parse_known_args()

    if not args.j:
        args.j = []
    if not args.y:
        args.y = []

    ctx = _merge_inputs(args)

    if args.var:
        value = _get_path(ctx, args.var)
        if isinstance(value, (dict, list)):
            sys.stdout.write(json.dumps(value))
        else:
            sys.stdout.write("" if value is None else str(value))
        sys.stdout.write("\n")
        return 0

    if args.write_to_db:
        _write_config_db(ctx)
        return 0

    if args.print_data:
        sys.stdout.write(json.dumps(ctx, indent=4))
        sys.stdout.write("\n")
        return 0

    if args.template:
        enable_asan = ctx.get("ENABLE_ASAN", os.environ.get("ENABLE_ASAN", "n"))
        rendered = _render_template(args.template, ctx, enable_asan)
        sys.stdout.write(rendered)
        return 0

    # Compatibility fallback: if nothing was requested, print the merged data.
    sys.stdout.write(json.dumps(ctx, indent=4))
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
