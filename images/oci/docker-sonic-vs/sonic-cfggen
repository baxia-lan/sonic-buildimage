    platform = os.environ.get("PLATFORM", DEFAULT_PLATFORM)
    hwsku = os.environ.get("HWSKU", DEFAULT_HWSKU)
    switch_type = os.environ.get("SWITCH_TYPE", DEFAULT_SWITCH_TYPE)
    device_type = DEFAULT_DEVICE_TYPE
    if hwsku == "DPU-2P":
        device_type = "SmartSwitchDPU"
        switch_type = "dpu"

    metadata = {
        "hostname": hostname,
        "platform": platform,
        "hwsku": hwsku,
        "type": device_type,
        "switch_type": switch_type,
