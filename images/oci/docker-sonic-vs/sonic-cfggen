    }


def _merge_inputs(args: argparse.Namespace) -> Dict[str, Any]:
    ctx = _build_base_context()

    if args.d:
        # When running in the live docker-vs container, prefer the current config db
        # as the "default" data source if it already exists.
        config_db_json = "/etc/sonic/config_db.json"
        if os.path.exists(config_db_json):
            try:
                _deep_merge(ctx, _load_json_like(config_db_json))
            except Exception:
                pass

    for file_name in args.y or []:
        _deep_merge(ctx, _load_json_like(file_name))

    for file_name in args.j or []:
        _deep_merge(ctx, _load_json_like(file_name))

    if args.a:
        _deep_merge(ctx, json.loads(args.a))

    if args.platform_json or args.hwsku:
        # Retain a deterministic DVS-friendly port model. The platform/hwsku
        # arguments are accepted for compatibility but the runtime structure is
        # intentionally based on the local VS hwsku port_config.ini.
        ctx["DEVICE_METADATA"]["localhost"]["platform"] = os.environ.get("PLATFORM", DEFAULT_PLATFORM)
        ctx["DEVICE_METADATA"]["localhost"]["hwsku"] = args.hwsku or os.environ.get("HWSKU", DEFAULT_HWSKU)
        ctx["DEVICE_METADATA"]["localhost"]["switch_type"] = os.environ.get("SWITCH_TYPE", DEFAULT_SWITCH_TYPE)
        ctx["DEVICE_METADATA"]["localhost"]["type"] = DEFAULT_DEVICE_TYPE
        if not ctx.get("PORT"):
            ctx["PORT"] = _port_table_from_ini("/usr/share/sonic/hwsku/port_config.ini")

    # Keep the init_cfg-derived metadata available in the default data path.
    ctx["DEVICE_METADATA"]["localhost"].setdefault("platform", os.environ.get("PLATFORM", DEFAULT_PLATFORM))
    ctx["DEVICE_METADATA"]["localhost"].setdefault("hwsku", os.environ.get("HWSKU", DEFAULT_HWSKU))
    ctx["DEVICE_METADATA"]["localhost"].setdefault("type", DEFAULT_DEVICE_TYPE)
    ctx["DEVICE_METADATA"]["localhost"].setdefault("switch_type", os.environ.get("SWITCH_TYPE", DEFAULT_SWITCH_TYPE))
    ctx["DEVICE_METADATA"]["localhost"].setdefault("mac", _mac_from_eth0())
    ctx["DEVICE_METADATA"]["localhost"].setdefault("asic_id", "0")
    return ctx


def _render_supervisord(enable_asan: str) -> str:
    template_candidates = [
        Path("/usr/share/sonic/templates/supervisord.conf.j2"),
        Path("platform/vs/docker-sonic-vs/supervisord.conf.j2"),
    ]
    template_path = next((path for path in template_candidates if path.exists()), None)
    if template_path is None:
        raise SystemExit("Missing supervisord.conf.j2 template")
    out: List[str] = []
    include = True
    with template_path.open("r", encoding="utf-8") as fh:
        for raw in fh:
            line = raw.rstrip("\n")
            stripped = line.strip()
            if stripped == '{% if ENABLE_ASAN == "y" %}':
                include = enable_asan == "y"
                continue
            if stripped == "{% endif %}":
                include = True
                continue
            if not include:
                continue
            out.append(line.replace("{{ asan_extra_options }}", ":print_suppressions=0"))
    return "\n".join(out) + "\n"


