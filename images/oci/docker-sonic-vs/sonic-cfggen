DEFAULT_DEVICE_TYPE = "ToRRouter"
DEFAULT_ASIC_TYPE = "vs"


def _load_json_like(path: str) -> Dict[str, Any]:
    with open(path, "r", encoding="utf-8") as fh:
        text = fh.read().strip()
    if not text:
        return {}
    if path.endswith((".yml", ".yaml")):
        return _load_simple_yaml(text)
    return json.loads(text)


def _load_simple_yaml(text: str) -> Dict[str, Any]:
    data: Dict[str, Any] = {}
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if value.startswith(("'", '"')) and value.endswith(("'", '"')):
            value = value[1:-1]
        data[key] = value
    return data


def _deep_merge(dst: Dict[str, Any], src: Dict[str, Any]) -> Dict[str, Any]:
    for key, value in src.items():
        if isinstance(value, dict) and isinstance(dst.get(key), dict):
            _deep_merge(dst[key], value)
        else:
            dst[key] = value
    return dst


def _get_path(data: Any, path: str) -> Any:
    expr = path.strip()
    if not expr:
        return ""

    # Special case used by start.sh.
    if expr == 'VLAN.keys() | join(" ") if VLAN' or expr == "VLAN.keys() | join(' ') if VLAN":
        vlan = data.get("VLAN") if isinstance(data, dict) else None
        if not vlan:
            return ""
        return " ".join(vlan.keys())

    expr = re.sub(r"\[['\"]([^'\"]+)['\"]\]", r".\1", expr)
    expr = expr.replace(" ", "")
    expr = expr.split("|", 1)[0]
    expr = expr.split("(", 1)[0]

    node: Any = data
    for token in expr.split("."):
        if not token:
            continue
        if isinstance(node, dict) and token in node:
            node = node[token]
            continue
        return ""
    return node


def _mac_from_eth0() -> str:
    for candidate in (
        ["/bin/sh", "-c", "cat /sys/class/net/eth0/address 2>/dev/null"],
        ["/bin/sh", "-c", "ip link show eth0 2>/dev/null | awk '/link\\/ether/ {print $2; exit}'"],
    ):
        try:
            out = subprocess.check_output(candidate, text=True).strip()
            if out:
                return out
        except Exception:
            continue
    return "00:00:00:00:00:00"


def _load_hwsku_default_modes() -> Dict[str, str]:
    hwsku_files = [
        "/usr/share/sonic/device/x86_64-kvm_x86_64-r0/Force10-S6000/hwsku.json",
        "/usr/share/sonic/device/x86_64-kvm_x86_64-r0/brcm_gearbox_vs/hwsku.json",
        "/usr/share/sonic/device/x86_64-kvm_x86_64-r0/Mellanox-SN2700/hwsku.json",
    ]
    for hwsku_file in hwsku_files:
        if not os.path.exists(hwsku_file):
            continue
        try:
            with open(hwsku_file, "r", encoding="utf-8") as fh:
                data = json.load(fh)
            interfaces = data.get("interfaces", {})
            if isinstance(interfaces, dict) and interfaces:
                return {
                    name: str(attrs.get("default_brkout_mode", "1x100G[40G]"))
                    for name, attrs in interfaces.items()
                    if isinstance(attrs, dict)
                }
        except Exception:
            continue
    return {}


def _port_table_from_ini(path: str) -> Dict[str, Dict[str, str]]:
    ports: Dict[str, Dict[str, str]] = {}
    default_modes = _load_hwsku_default_modes()
    index = 0
    with open(path, "r", encoding="utf-8") as fh:
        for raw in fh:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split()
            if len(parts) < 2:
                continue
            name = parts[0]
            lanes = parts[1]
            ports[name] = {
                "alias": name,
                "lanes": lanes,
                "index": str(index),
                "admin_status": "down",
                "mtu": "9100",
                "speed": "100000",
            }
            if name in default_modes:
                ports[name]["default_brkout_mode"] = default_modes[name]
            index += 1
    return ports


def _build_base_context() -> Dict[str, Any]:
